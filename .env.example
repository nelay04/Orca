# Copy this file to .env and fill in real values. Never commit .env.

# Application
APP_NAME=orca2echo
# Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-django-secret-key-here
DEBUG=True

# Server bind address used by `python manage.py runasgi`
HOST=127.0.0.1
PORT=8000

# Public base URL. Used for CSRF trusted origins and for the profile links
# embedded in generated QR codes.
APP_URL=http://127.0.0.1:8000

# Comma-separated hostnames this app will answer for.
# Set to your real domain in production. Do not use '*'.
ALLOWED_HOSTS=127.0.0.1,localhost

# Optional. Only applies when DEBUG=False. Set to False if a reverse proxy
# such as nginx already terminates TLS and redirects HTTP itself, otherwise
# you get a redirect loop.
SECURE_SSL_REDIRECT=True

# Optional. HTTP Strict Transport Security, in seconds. 0 disables it.
# Set to 31536000 (one year) only once HTTPS works on every subdomain:
# a browser that has seen this header refuses plain HTTP until it expires,
# and you cannot take that back by reconfiguring the server.
SECURE_HSTS_SECONDS=0

# Docker-only overrides. These exist so the values above, which are correct
# for running directly on your machine, cannot leak into a container where
# they would be wrong or unsafe. Leave them unset unless you need them.
#   DOCKER_BIND=0.0.0.0        publish the container on all interfaces
#   DOCKER_DEBUG=True          enable Django debug inside the container
#   DOCKER_SSL_REDIRECT=True   let Django do the https redirect itself

# Databases
# ---------------------------------------------------------------------
# COMPOSE_PROFILES decides which database containers Docker creates.
# Leave a URL blank for anything you run as a container; set it for
# anything hosted. Running without Docker? COMPOSE_PROFILES is ignored,
# just set both URLs.
#
#   Both in Docker      COMPOSE_PROFILES=bundled-db
#                       DATABASE_URL=         REDIS_URL=
#
#   Both hosted         COMPOSE_PROFILES=
#                       DATABASE_URL=postgres://...   REDIS_URL=redis://host:6379
#
#   Postgres hosted,    COMPOSE_PROFILES=bundled-redis
#   Redis in Docker     DATABASE_URL=postgres://...   REDIS_URL=
#
#   Postgres in Docker, COMPOSE_PROFILES=bundled-postgres
#   Redis hosted        DATABASE_URL=         REDIS_URL=redis://host:6379
#
#   Add the pgAdmin UI  COMPOSE_PROFILES=bundled-db,pgadmin
#
# The list is comma-separated, so bundled-postgres,bundled-redis is the
# same as bundled-db. A container that is not in an active profile is
# never created, so it uses no memory.
#
# A loopback address never works under Docker: inside a container
# 127.0.0.1 is the container itself, not your host.
#
# No Docker, with the bundled Postgres published on the host:
#   DATABASE_URL=protocol://username:password@host:port/database_name
#   REDIS_URL=redis://127.0.0.1:6379
#
# There is no SQLite fallback. The app refuses to start without a
# PostgreSQL DATABASE_URL.
COMPOSE_PROFILES=bundled-db
DATABASE_URL=
REDIS_URL=

# Credentials for the bundled PostgreSQL container, and the port it both
# listens on and is published to. Only used when Postgres runs as a
# container; a hosted database carries its own credentials in DATABASE_URL.
# Change POSTGRES_PASSWORD before running anywhere but your own machine.
POSTGRES_DB=orca
POSTGRES_USER=orca
POSTGRES_PASSWORD=orca
POSTGRES_PORT=5434

# Optional pgAdmin container, only created with the "pgadmin" profile.
# It runs in single-user desktop mode, which opens with no login screen, so
# anyone who can reach PGADMIN_PORT owns the database. Keep it local.
# Avoid 5060: Chrome and Edge block it (SIP) and show ERR_UNSAFE_PORT.
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
# Single-user desktop mode (no login screen). Only set to True if you put
# pgAdmin behind a real login and know what you are doing.
PGADMIN_CONFIG_SERVER_MODE=False

# Email used to deliver sign-in OTPs.
# For Gmail this is an App Password, not your account password:
# Google Account -> Security -> 2-Step Verification -> App passwords
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# Dedicated key for profile and conversation tokens. When unset, a key is
# derived from SECRET_KEY instead, which means rotating SECRET_KEY also
# invalidates every shared profile link. Setting this decouples the two.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Whenever you change this (or change SECRET_KEY while this is unset), delete
# orca2echo/static/qr/ as well. Those PNGs encode links built with the old key
# and are cached by filename, so they will not regenerate on their own.
FERNET_KEY=

# Optional. Only used by entrypoint.sh to bootstrap an admin account in Docker.
# Leave unset to skip creation and run `python manage.py createsuperuser` by hand.
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# Optional. Push notification keys. Generate with:
#   python scripts/generate_vapid_keys.py
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
